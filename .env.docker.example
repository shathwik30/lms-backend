# ── Environment ──────────────────────────────────────────────────────────────
# Single-VM docker-compose production stack (Postgres + Redis + Celery in-compose).
# Copy to .env.docker on the VM and fill in real values.
DJANGO_ENV=production

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token_urlsafe-64
DEBUG=False
ALLOWED_HOSTS=yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── Database (internal postgres service from docker-compose) ─────────────────
DATABASE_URL=postgres://lms_user:change-me-strong-password@db:5432/lms_db
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change-me-strong-password
DB_CONN_MAX_AGE=600

# ── Redis (internal redis service from docker-compose) ──────────────────────
REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
CACHE_LOCATION=redis://redis:6379/1

# ── Celery (real worker in compose — do NOT use eager in prod) ──────────────
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_EAGER_PROPAGATES=False
CELERY_CONCURRENCY=2

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── Email (Resend) ──────────────────────────────────────────────────────────
EMAIL_BACKEND=core.email_backends.ResendEmailBackend
RESEND_API_KEY=re_change_me
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Frontend URL (used in password reset / verification email links) ────────
FRONTEND_URL=https://yourdomain.com

# ── Logging ─────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO

# ── Sentry (optional) ───────────────────────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Gunicorn ────────────────────────────────────────────────────────────────
WEB_CONCURRENCY=3
PORT=8000
