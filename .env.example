# ── Environment ──────────────────────────────────────────────────────────────
# "development" → console email, SQLite, no throttling, Celery eager mode
# "production"  → Resend email, PostgreSQL, Redis cache, security hardening
DJANGO_ENV=development

# ── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/lms_db
# DB_CONN_MAX_AGE=600

# ── Redis ────────────────────────────────────────────────────────────────────
# Used by Celery (broker + result backend) and cache in production.
# Railway provides this automatically when you add a Redis addon.
# REDIS_URL=redis://localhost:6379/0

# ── Cache ────────────────────────────────────────────────────────────────────
# CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
# CACHE_LOCATION=lms-cache

# ── Celery ───────────────────────────────────────────────────────────────────
# Run tasks synchronously in dev (no Redis/worker needed)
CELERY_TASK_ALWAYS_EAGER=True
CELERY_TASK_EAGER_PROPAGATES=True
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Dev defaults to console backend (no API key needed).
# Production uses Resend — set RESEND_API_KEY.
# EMAIL_BACKEND=core.email_backends.ResendEmailBackend
# RESEND_API_KEY=re_xxxxxxxxxxxx
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── Razorpay (leave empty for dev — skips payment gateway) ───────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Frontend URL (for password reset links) ──────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Logging ──────────────────────────────────────────────────────────────────
DJANGO_LOG_LEVEL=INFO

# ── Sentry (production only — optional) ─────────────────────────────────────
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# ── Railway (auto-set by Railway platform) ──────────────────────────────────
# RAILWAY_PUBLIC_DOMAIN=your-app.up.railway.app

# ── Gunicorn (production only) ──────────────────────────────────────────────
# WEB_CONCURRENCY=3
# PORT=8000
