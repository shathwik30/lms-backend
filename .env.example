# Environment: "development" or "production"
# For deployment, set DJANGO_ENV=production (enables secure defaults, disables DEBUG, etc.)
DJANGO_ENV=development

# Django
SECRET_KEY=change-me-to-a-real-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
# Production: ALLOWED_HOSTS=yourdomain.com

# Database (PostgreSQL recommended for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/lms_db

# Database connection pooling (production only)
# DB_CONN_MAX_AGE=600

# Docker Compose Postgres credentials (used by docker-compose.yml)
# Override these in .env.docker for production — never commit real credentials
POSTGRES_DB=lms_db
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=lms_pass

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CSRF (required in production when CORS origins differ from ALLOWED_HOSTS)
# CSRF_TRUSTED_ORIGINS=https://your-domain.com

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# CELERY_CONCURRENCY=2  # Worker concurrency (default: 2 in Docker)
# WEB_CONCURRENCY=3     # Gunicorn worker count (default: 2*CPU+1)

# Cache (LocMemCache for dev, RedisCache for production — used by OTP)
# CACHE_BACKEND=django.core.cache.backends.redis.RedisCache
# CACHE_LOCATION=redis://localhost:6379/1

# Razorpay (leave empty for dev mode — skips payment gateway)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (defaults to console backend for dev)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@lms.com

# Google OAuth (for Google Sign-In)
GOOGLE_CLIENT_ID=

# Frontend URL (for password reset links)
FRONTEND_URL=http://localhost:3000

# Logging
DJANGO_LOG_LEVEL=INFO

# Sentry (production only — error tracking)
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1
